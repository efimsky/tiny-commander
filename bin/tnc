#!/bin/sh
# Tiny Commander launcher.
#
# Picks the newest python3.X (X >= 13) available on PATH, so users with both
# an older `python3` symlink (e.g. 3.12) and a newer interpreter installed
# alongside it (e.g. /usr/bin/python3.14) automatically get the newer one.
#
# Falls back to plain `python3` when no versioned binary is found, letting
# tnc/_version_check.py print a clean "requires 3.13+" error if it's too old.

case "$0" in
    */*) SCRIPT_DIR=$(cd "${0%/*}" && pwd) ;;
    *)   SCRIPT_DIR=$(pwd) ;;
esac
PROJECT_ROOT=${SCRIPT_DIR%/*}
export PYTHONPATH="$PROJECT_ROOT${PYTHONPATH:+:$PYTHONPATH}"

# Newest first. Extend the list as new Python releases ship.
for ver in 3.20 3.19 3.18 3.17 3.16 3.15 3.14 3.13; do
    if command -v "python${ver}" >/dev/null 2>&1; then
        exec "python${ver}" -m tnc "$@"
    fi
done

if command -v python3 >/dev/null 2>&1; then
    exec python3 -m tnc "$@"
fi

echo "tnc requires Python 3.13 or newer (no python3 found on PATH)." >&2
exit 1
